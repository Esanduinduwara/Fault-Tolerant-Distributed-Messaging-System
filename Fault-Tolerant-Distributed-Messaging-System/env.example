# ── Kafka (3-broker cluster) ───────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093,localhost:9094
KAFKA_TOPIC_NAME=user-messages
KAFKA_REPLICATION_FACTOR=3
KAFKA_MIN_INSYNC_REPLICAS=2

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://admin:password123@localhost:27017/messaging_app?authSource=admin
MONGODB_DATABASE=messaging_app

# ── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── App ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_RETRIES=3
BATCH_SIZE=100

# ── Time Synchronization (Part 3) ─────────────────────────────────────────
NTP_SERVERS=pool.ntp.org,time.google.com,time.windows.com
NTP_SYNC_INTERVAL_S=60
REORDER_BUFFER_WINDOW_MS=500

# ── Fault Detection (Part 1) ──────────────────────────────────────────────
HEARTBEAT_INTERVAL_S=5
HEARTBEAT_TIMEOUT_S=15
